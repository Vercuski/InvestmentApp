@using InvestmentApp.Presentation.Web.Components
@inherits LayoutComponentBase

<MyMudThemeProvider IsDarkMode="_isDarkMode"/>
<MudDialogProvider />
<div class="page mud-layout">
    <div class="sidebar mud-elevation-1">
        <div class="top-row mud-drawer-head">
        </div>
        <input type="checkbox" title="Navigation menu" class="navbar-toggler" />
        <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
            <NavMenu />
        </div>
    </div>

    <main>
        <div class="top-row px-4">
            <MudSwitch T="bool" @bind-Value="_isDarkMode" Label="Dark mode" Color="Color.Primary" />
        </div>
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-2 pt-2">
            @Body
        </MudContainer>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _isDarkMode;
}
