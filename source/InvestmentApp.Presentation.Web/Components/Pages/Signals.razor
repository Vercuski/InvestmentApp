@page "/signals"
@using InvestmentApp.Application.Contracts.Poco
@using InvestmentApp.Domain.Entities
@using InvestmentApp.Domain.Enums
@inject IHttpClientFactory HttpClientFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Signals</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Trade signals</MudText>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="3">
    <MudNumericField T="int" @bind-Value="_confidenceLevel" Label="Confidence level" Min="0" Max="100"
                      Adornment="Adornment.End" AdornmentText="%" Style="width:180px;" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadSignalsAsync" Disabled="_loading">
        Reevaluate
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="ma-4" />
}
else if (_loadError)
{
    <MudAlert Severity="Severity.Error" Class="ma-4">
        Couldn't reach the Investment API at the configured base URL. Check that it's running and reachable.
    </MudAlert>
}
else
{
    <MudGrid Class="mb-4">
        <MudItem xs="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Buy signals</MudText>
                <MudText Typo="Typo.h5" Color="Color.Success">@_buys.Count</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Sell signals</MudText>
                <MudText Typo="Typo.h5" Color="Color.Error">@_sells.Count</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Avg confidence</MudText>
                <MudText Typo="Typo.h5">@_avgConfidence.ToString("P0")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Active tickers</MudText>
                <MudText Typo="Typo.h5">@_activeTickerCount</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" />
                    <MudText Typo="Typo.subtitle1">Latest buys</MudText>
                </MudStack>
                @if (_buys.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">No buy signals in the latest run.</MudText>
                }
                else
                {
                    <MudTable Items="_buys" Hover="true" Dense="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Exchange</MudTh>
                            <MudTh>Ticker</MudTh>
                            <MudTh>Regime</MudTh>
                            <MudTh>Confidence</MudTh>
                            <MudTh>Close</MudTh>
                            <MudTh>Stop loss</MudTh>
                            <MudTh>Position</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Exchange">@context.ExchangeSymbol</MudTd>
                            <MudTd DataLabel="Ticker"><MudText Style="font-weight:500;">@context.TickerSymbol</MudText></MudTd>
                            <MudTd DataLabel="Regime">
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(context.Regime == "Trending" ? Color.Primary : Color.Default)"
                                         Variant="@(context.Regime == "Trending" ? Variant.Filled : Variant.Outlined)">
                                    @context.Regime
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Confidence">
                                <MudProgressLinear Color="Color.Success" Value="@((double)context.Confidence * 100)" Class="my-1" Style="width:80px;" />
                            </MudTd>
                            <MudTd DataLabel="Close">@context.Close.ToString("C")</MudTd>
                            <MudTd DataLabel="Stop loss">@context.StopLossPrice.ToString("C")</MudTd>
                            <MudTd DataLabel="Position">
                                @if (context.TickerSymbol is not null && !_openPositionsByTicker.TryGetValue(context.TickerSymbol, out var openPosition))
                                {
                                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => OpenBuyDialogAsync(context))">
                                        Buy
                                    </MudButton>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Error" />
                    <MudText Typo="Typo.subtitle1">Latest sells</MudText>
                </MudStack>
                @if (_sells.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">No sell signals in the latest run.</MudText>
                }
                else
                {
                    <MudTable Items="_sells" Hover="true" Dense="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Exchange</MudTh>
                            <MudTh>Ticker</MudTh>
                            <MudTh>Regime</MudTh>
                            <MudTh>Confidence</MudTh>
                            <MudTh>Close</MudTh>
                            <MudTh>Stop loss</MudTh>
                            <MudTh>Position</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Exchange">@context.ExchangeSymbol</MudTd>
                            <MudTd DataLabel="Ticker"><MudText Style="font-weight:500;">@context.TickerSymbol</MudText></MudTd>
                            <MudTd DataLabel="Regime">
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(context.Regime == "Trending" ? Color.Primary : Color.Default)"
                                         Variant="@(context.Regime == "Trending" ? Variant.Filled : Variant.Outlined)">
                                    @context.Regime
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Confidence">
                                <MudProgressLinear Color="Color.Error" Value="@((double)context.Confidence * 100)" Class="my-1" Style="width:80px;" />
                            </MudTd>
                            <MudTd DataLabel="Close">@context.Close.ToString("C")</MudTd>
                            <MudTd DataLabel="Stop loss">@context.StopLossPrice.ToString("C")</MudTd>
                            <MudTd DataLabel="Position">
                                @if (context.TickerSymbol is not null && _openPositionsByTicker.TryGetValue(context.TickerSymbol, out var openPosition))
                                {
                                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error" OnClick="@(() => SellPositionAsync(openPosition, context))">
                                        Sell
                                    </MudButton>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private List<TradeSignalPointPoco> _buys = [];
    private List<TradeSignalPointPoco> _sells = [];
    private Dictionary<string, PositionPoint> _openPositionsByTicker = new(StringComparer.OrdinalIgnoreCase);
    private int _activeTickerCount;
    private decimal _avgConfidence;
    private int _confidenceLevel = 100;
    private bool _loading = true;
    private bool _loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadSignalsAsync();
    }

    private async Task LoadSignalsAsync()
    {
        _loading = true;
        _loadError = false;
        StateHasChanged();

        var client = HttpClientFactory.CreateClient("InvestmentApi");

        try
        {
            var buysTask = client.GetFromJsonAsync<List<TradeSignalPointPoco>>($"api/TradeSignalPoint/LatestBuys?confidenceLevel={_confidenceLevel}");
            var sellsTask = client.GetFromJsonAsync<List<TradeSignalPointPoco>>($"api/TradeSignalPoint/LatestSells?confidenceLevel={_confidenceLevel}");
            var positionsTask = client.GetFromJsonAsync<List<PositionPoint>>("api/Positions");
            await Task.WhenAll(buysTask, sellsTask, positionsTask);

            _buys = buysTask.Result ?? [];
            _sells = sellsTask.Result ?? [];
            SetOpenPositions(positionsTask.Result ?? []);

            var allSignals = _buys.Concat(_sells).ToList();
            _avgConfidence = allSignals.Count > 0 ? allSignals.Average(s => s.Confidence) : 0m;
            _activeTickerCount = allSignals.Select(s => s.TickerSymbol).Distinct().Count();
        }
        catch (HttpRequestException)
        {
            _loadError = true;
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetOpenPositions(List<PositionPoint> positions)
    {
        _openPositionsByTicker = positions
            .Where(p => p.SellDate is null && p.TickerSymbol is not null)
            .GroupBy(p => p.TickerSymbol!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.First(), StringComparer.OrdinalIgnoreCase);
    }

    private async Task OpenBuyDialogAsync(TradeSignalPointPoco signal)
    {
        var regime = Enum.TryParse<MarketRegime>(signal.Regime, true, out var parsedRegime)
            ? parsedRegime
            : MarketRegime.Ranging;

        var newPosition = new PositionPoint
        {
            TickerSymbol = signal.TickerSymbol,
            ExchangeSymbol = signal.ExchangeSymbol,
            Regime = regime,
            Confidence = signal.Confidence,
            PurchasePrice = signal.Close,
            PurchaseDate = signal.Date == default ? DateTime.Today : signal.Date
        };

        var parameters = new DialogParameters<PositionEditDialog>
        {
            { x => x.Position, newPosition }
        };
        var dialog = await DialogService.ShowAsync<PositionEditDialog>("Buy position", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not PositionPoint position)
        {
            return;
        }

        await SavePositionAsync(position, $"Bought {position.TickerSymbol}.");
    }

    private async Task SellPositionAsync(PositionPoint openPosition, TradeSignalPointPoco signal)
    {
        var sellDate = signal.Date == default ? DateTime.Today : signal.Date;

        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "Sell position",
            $"Sell {openPosition.NumberOfShares:N4} shares of {openPosition.TickerSymbol} at {signal.Close:C}?",
            yesText: "Sell",
            cancelText: "Cancel");

        if (confirmed != true)
        {
            return;
        }

        var closedPosition = openPosition with
        {
            SellPrice = signal.Close,
            SellDate = sellDate
        };

        await SavePositionAsync(closedPosition, $"Sold {closedPosition.TickerSymbol}.");
    }

    private async Task SavePositionAsync(PositionPoint position, string successMessage)
    {
        var client = HttpClientFactory.CreateClient("InvestmentApi");

        try
        {
            var response = await client.PutAsJsonAsync("api/Positions", position);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(successMessage, Severity.Success);
                await LoadSignalsAsync();
            }
            else
            {
                Snackbar.Add("Failed to save position.", Severity.Error);
            }
        }
        catch (HttpRequestException)
        {
            Snackbar.Add("Couldn't reach the Investment API.", Severity.Error);
        }
    }
}
